{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Privata",
  "description": "API and SDK for integrating Privata swap aggregator into crypto wallets. 50+ providers, single REST surface, privacy by design.",
  "colors": {
    "primary": "#7C5CFF",
    "light": "#A491FF",
    "dark": "#4F3BC4"
  },
  "logo": {
    "light": "/images/logo-light.svg",
    "dark": "/images/logo-dark.svg",
    "href": "https://privataswap.com"
  },
  "favicon": "/images/favicon.svg",
  "appearance": {
    "default": "dark",
    "strict": false
  },
  "background": {
    "color": {
      "light": "#FFFFFF",
      "dark": "#0A0A12"
    }
  },
  "navbar": {
    "links": [
      { "label": "Dashboard", "href": "https://dashboard.privataswap.com" },
      { "label": "Status", "href": "https://status.privataswap.com" }
    ],
    "primary": {
      "type": "button",
      "label": "Get API key",
      "href": "https://dashboard.privataswap.com/signup"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Get started",
            "pages": ["index", "guides/quickstart", "guides/authentication"]
          },
          {
            "group": "Core flows",
            "pages": [
              "guides/order-lifecycle",
              "guides/refund-flow",
              "guides/sse-streaming",
              "guides/webhooks",
              "guides/sandbox"
            ]
          },
          {
            "group": "Operations",
            "pages": [
              "guides/rate-limits",
              "guides/errors",
              "guides/sla",
              "guides/ops-events",
              "guides/changelog"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Overview",
            "pages": ["api-reference/introduction"]
          },
          {
            "group": "Endpoints",
            "openapi": {
              "source": "/api-reference/openapi.yaml",
              "directory": "api-reference"
            }
          }
        ]
      },
      {
        "tab": "SDK",
        "groups": [
          {
            "group": "JavaScript / TypeScript",
            "pages": [
              "sdk/js/install",
              "sdk/js/quickstart",
              "sdk/js/configuration",
              "sdk/js/errors",
              "sdk/js/streaming"
            ]
          },
          {
            "group": "Compatibility layers",
            "pages": [
              "sdk/compat/changenow",
              "sdk/compat/trocador"
            ]
          }
        ]
      }
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/privataswap",
      "github": "https://github.com/privataswap",
      "telegram": "https://t.me/privataswap"
    },
    "links": [
      {
        "header": "Product",
        "items": [
          { "label": "Swap", "href": "https://privataswap.com" },
          { "label": "Dashboard", "href": "https://dashboard.privataswap.com" },
          { "label": "Status", "href": "https://status.privataswap.com" }
        ]
      },
      {
        "header": "Developers",
        "items": [
          { "label": "API Reference", "href": "https://docs.privataswap.com/api-reference" },
          { "label": "SDK", "href": "https://docs.privataswap.com/sdk/js/install" },
          { "label": "Changelog", "href": "https://docs.privataswap.com/guides/changelog" }
        ]
      },
      {
        "header": "Legal",
        "items": [
          { "label": "Terms", "href": "https://privataswap.com/terms" },
          { "label": "Privacy", "href": "https://privataswap.com/privacy" }
        ]
      }
    ]
  },
  "search": {
    "prompt": "Ask the Privata docs..."
  },
  "seo": {
    "metatags": {
      "og:site_name": "Privata Docs",
      "twitter:site": "@privataswap"
    },
    "indexing": "all"
  },
  "integrations": {
    "ga4": { "measurementId": "G-PRIVATA" },
    "plausible": { "domain": "docs.privataswap.com" }
  },
  "contextual": {
    "options": ["copy", "view", "chatgpt", "claude", "perplexity"]
  }
}
